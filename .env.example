# ═══════════════════════════════════════════════
# Menu-Rest — Environment Variables
# Скопируйте в .env и заполните значения
# НИКОГДА не коммитьте .env в git!
# ═══════════════════════════════════════════════

# ─── PostgreSQL ───────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=menurest
DB_USER=menurest
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_SYNC=false          # true только для dev, false для prod!
DB_LOGGING=false

# ─── Redis ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=        # Оставить пустым если без пароля
REDIS_TTL=3600         # TTL кеша по умолчанию (секунды)

# ─── Elasticsearch ────────────────────────────
ES_HOST=http://elasticsearch:9200
ES_INDEX_RESTAURANTS=restaurants

# ─── MinIO / S3 ───────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_USER=minioadmin
MINIO_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=menurest-photos
MINIO_PUBLIC_URL=http://localhost:9000

# ─── JWT Auth ─────────────────────────────────
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_LONG_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ─── OAuth VK ─────────────────────────────────
VK_APP_ID=
VK_APP_SECRET=

# ─── Telegram Login ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ─── AI Search (Ollama) ──────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
LLM_TIMEOUT_MS=10000        # Таймаут LLM запроса (мс)
AI_CACHE_TTL=3600            # Кеш AI-ответов в Redis (сек)

# ─── App URLs ─────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
PUBLIC_URL=https://new.menu-rest.com

# ─── CORS ─────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://new.menu-rest.com

# ─── Rate Limiting ────────────────────────────
THROTTLE_TTL=60000    # окно в мс
THROTTLE_LIMIT=100    # запросов в окне

# ─── Legacy Import (MariaDB / MySQL) ──────────
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=3306
LEGACY_DB_NAME=menu_rest
LEGACY_DB_USER=root
LEGACY_DB_PASSWORD=

# Базовый URL для фото из rest_rest_photo (filename → полный URL)
# Пример: https://old.menu-rest.com/uploads  или  /legacy-photos
LEGACY_PHOTO_BASE_URL=https://old.menu-rest.com/uploads
